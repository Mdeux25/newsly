# News API Keys
# Get your free API key from: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# RapidAPI Key (for Arabic News API)
# Subscribe at: https://rapidapi.com/ruamazi/api/arabic-news-api
RAPIDAPI_KEY=your_rapidapi_key_here

# GNews API Key (Optional - backup source)
# Get your free API key from: https://gnews.io/register
GNEWS_KEY=your_gnews_key_here

# Twitter/X API (Optional)
# Get your Bearer Token from: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
# MySQL database connection settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=news_user
DB_PASSWORD=your_secure_password_here
DB_NAME=news_aggregator

# Worker Configuration
# How often to fetch news (in minutes)
FETCH_INTERVAL_MINUTES=15
# How many days to keep articles in database
ARTICLE_RETENTION_DAYS=7
# Maximum articles to fetch per request
MAX_ARTICLES_PER_FETCH=50

# Facebook Auto-Poster
# Set FB_POST_ENABLED=true to activate automated posting
FB_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token_here
FB_PAGE_ID=your_facebook_page_id_here
FB_POST_ENABLED=false
# How often to post (in hours, default: 3 → max 8 posts/day)
FB_POST_INTERVAL_HOURS=3
# Max articles to post per run (default: 3)
FB_POST_LIMIT=3
# Set to true to use Gemini LLM for captions instead of the template
FB_USE_LLM_CAPTION=false
